# Watcher Environment Variables
# Copy this to .env and fill in your values

# Anthropic API Key (required for Stage 2: Synthesize)
ANTHROPIC_API_KEY=your-api-key-here

# Slack Webhook URL (optional for Stage 3: Deliver)
# If set, digest will be posted to this Slack incoming webhook
# Get your webhook URL at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
